# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
# Without this, a rule-based fallback runs instead of Claude AI.
ANTHROPIC_API_KEY=sk-ant-...

# ── Plaid (Bank Connections) ──────────────────────────────────────────────────
# Sign up free at: https://dashboard.plaid.com/signup
# Use "sandbox" for testing with fake banks (no real credentials needed)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox
# Options: sandbox | development | production
